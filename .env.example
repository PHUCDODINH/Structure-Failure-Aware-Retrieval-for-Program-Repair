OPENAI_API_KEY=replace-with-your-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT=60
OPENAI_MAX_RETRIES=4
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1

# Optional retrieval overrides
